{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "vnetEnabled": {
      "value": "${VNET_ENABLED=false}"
    },
    "openAiDeploymentName": {
      "value": "${AZURE_OPENAI_DEPLOYMENT=gpt-5-mini}"
    },
    "openAiModelName": {
      "value": "${AZURE_OPENAI_MODEL=gpt-5-mini}"
    },
    "openAiModelVersion": {
      "value": "${AZURE_OPENAI_MODEL_VERSION=2025-08-07}"
    },
    "openAiCapacity": {
      "value": "${AZURE_OPENAI_CAPACITY=30}"
    },
    "nasaApiKey": {
      "value": "${NASA_API_KEY=DEMO_KEY}"
    }
  }
}
