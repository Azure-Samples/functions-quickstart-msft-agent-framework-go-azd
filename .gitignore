# ── Go (from github.com/github/gitignore/blob/main/Go.gitignore) ──
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage.txt
coverage.html

# Dependency directories (uncomment if you commit a vendor tree in a separate PR)
# vendor/

# Go workspace file
go.work
go.work.sum

# ── Azure Functions / azd / Azurite ──
# Compiled Function App binary (built by `func start` and azd deploys)
bin/

# azd environment state (subscription IDs, deployment outputs — may contain secrets)
.azure/

# Azurite local storage emulator state
.azurite/
__azurite_db_*.json
__blobstorage__/
__queuestorage__/

# Local settings (may contain endpoints or keys — never commit)
local.settings.json.local

# ── Editors / OS ──
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# ── Env files ──
.env
*.env
!.env.example
